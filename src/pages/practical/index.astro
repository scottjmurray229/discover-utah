---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';
import GearRecommendations from '../../components/GearRecommendations.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Travel Tips', url: '/practical/' },
];

const pageTitle = 'Utah Practical Guide — Permits, Hiking, Seasons & Safety Tips';
const pageDescription = 'Everything you need to know before visiting Utah — slot canyon permits, desert safety, altitude UV, snake country gear, Mighty Five planning, and what to pack for canyon country.';

interface Tip {
  title: string;
  description: string;
  html?: string;
  tag?: string;
}

interface TipSection {
  topic: string;
  icon: string;
  tagline: string;
  gradient: string;
  tips: Tip[];
}

const sections: TipSection[] = [
  {
    topic: 'Getting to Utah',
    icon: '&#9992;',
    tagline: 'Salt Lake City is the main gateway — flying into SLC puts you within reach of all five national parks',
    gradient: 'linear-gradient(135deg, #E94560 0%, #C23152 100%)',
    tips: [
      {
        title: 'Salt Lake City International Airport (SLC)',
        description: 'Utah\'s primary gateway, recently expanded with a stunning new terminal. Direct flights from most major US hubs, plus international service from London, Mexico City, and Canada. The TRAX light rail ($2.50) connects the airport to downtown SLC in about 25 minutes. Uber/Lyft to downtown runs $20-35. Car rental desks are in the terminal — book early for summer and ski season when vehicles sell out.',
        tag: 'Main Hub',
      },
      {
        title: 'Driving In',
        description: 'I-15 is the main north-south artery running through Salt Lake City, Provo, and St. George. I-70 cuts across central Utah and is one of the most scenic interstates in America — though also one of the most remote (gas up before crossing). From Las Vegas (4.5 hours to Zion), Phoenix (4.5 hours to Page/Antelope Canyon), or Denver (7 hours to Moab) — road trips to Utah are rewarding from every direction.',
        tag: 'Pro Tip',
      },
      {
        title: 'Renting a Car',
        description: 'A rental car is not optional for the Mighty Five national parks — Zion, Bryce Canyon, Capitol Reef, Canyonlands, and Arches are not connected by public transit. Budget $50-90/day. For backcountry roads (Burr Trail, Canyonlands Island in the Sky, areas around Escalante), an AWD or high-clearance 4WD vehicle is strongly recommended after rain. Confirm your rental agreement covers dirt roads — some don\'t.',
        tag: 'Essential',
      },
      {
        title: 'Regional Airports',
        description: 'St. George Regional Airport (SGU) has service from Salt Lake City and some California hubs — useful for Zion-focused trips. Page Municipal Airport (PGA) near Antelope Canyon has limited service. Canyonlands Regional Airport (CNY) near Moab has seasonal flights from Denver. These small airports save 2-3 hours of driving but book out fast and cancel more frequently than major hub connections.',
      },
    ],
  },
  {
    topic: 'Permits & Planning',
    icon: '&#128196;',
    tagline: 'Utah\'s most iconic experiences require advance permits — plan months ahead or miss out',
    gradient: 'linear-gradient(135deg, #1E3A5F 0%, #152D4A 100%)',
    tips: [
      {
        title: 'The Wave & Antelope Canyon',
        description: 'The Wave (North Coyote Buttes, Utah/Arizona border) is one of the most coveted permits in the American West — 64 people per day, selected by lottery at recreation.gov. Apply 4 months in advance online or enter the day-before lottery in person at the Kanab visitor center. Antelope Canyon (near Page, AZ) requires a licensed Navajo guide — Upper Antelope Canyon sells out 3-6 months ahead in spring.',
        tag: 'Critical',
      },
      {
        title: 'Mighty Five Timed Entry',
        description: 'Zion National Park requires a shuttle reservation from spring through fall — you cannot drive your own car to Zion Canyon. Reserve at recreation.gov 3-6 months ahead for peak season (March-November). Arches National Park has timed entry permits required April through October ($2 per vehicle, reserved online). Bryce Canyon and Capitol Reef are currently permit-free but can be very crowded. Always check nps.gov before arrival.',
        tag: 'Important',
      },
      {
        title: 'Canyoneering Permits',
        description: 'Technical slot canyons require permits: The Subway in Zion (very competitive lottery, recreation.gov), Buckskin Gulch in Grand Staircase-Escalante, Peek-a-Boo and Spooky in Escalante. Many canyoneering routes require ropes, harnesses, and proper gear. If you are new to technical canyons, book a guided trip — inexperienced solo canyoneers die in Utah every year. Zion Adventure Company and Utah Canyon Outdoors offer excellent guided options.',
        tag: 'Be Prepared',
      },
      {
        title: 'Goblin Valley & Stargazing',
        description: 'Goblin Valley State Park ($20/vehicle) is one of the most underrated Utah parks — quirky hoodoo formations, near-zero light pollution, and significantly fewer crowds than the Mighty Five. No permits required. The park offers primitive camping ($35/night) inside the valley itself — waking up among the goblins is surreal. Bryce Canyon is also an International Dark Sky Park and hosts ranger-led astronomy nights in summer.',
        tag: 'Hidden Gem',
      },
    ],
  },
  {
    topic: 'When to Visit',
    icon: '&#127793;',
    tagline: 'Utah is a four-season destination — spring and fall are ideal, summer is intense, winter is underrated',
    gradient: 'linear-gradient(135deg, #1A2332 0%, #1E3A5F 100%)',
    tips: [
      {
        title: 'Spring: March – May',
        description: 'The best overall time for canyon country. Wildflowers bloom in April-May, temperatures are 60-80°F in the desert (freezing at night), and crowds are lower than summer. Snowmelt can make some dirt roads impassable in early spring — check road conditions. Capitol Reef\'s orchards bloom in April. The Wave lottery is extremely competitive but worth trying. Book accommodation in Moab and near Zion 4-6 months ahead.',
        tag: 'Best Overall',
      },
      {
        title: 'Summer: June – August',
        description: 'Peak season but genuinely brutal in southern Utah — Moab regularly hits 100-108°F in July and August. Canyon hiking in full sun at midday is dangerous. Adjust your schedule: hike at dawn (5-8am), rest midday, hike again at 5pm. Higher elevation parks (Bryce Canyon at 8,000ft, Cedar Breaks at 10,000ft) are comfortable even in July. Zion\'s narrows are actually excellent in summer — the water keeps you cool.',
        tag: 'Peak Season',
      },
      {
        title: 'Fall: September – November',
        description: 'Our top recommendation alongside spring. September has summer temperatures without the brutal July heat. October brings spectacular canyon color — red rock against golden cottonwoods along rivers. Crowds thin noticeably after Labor Day. Bryce Canyon\'s hoodoos dusted with October snow are iconic. November is cold but very uncrowded. Ski resorts open in late November at the earliest.',
        tag: 'Top Pick',
      },
      {
        title: 'Winter: December – March',
        description: 'Southern Utah (Zion, Bryce, Arches) stays open year-round and winter visits are magical — no crowds, clear air, and dramatic snow on red rock. Temperatures in Zion Valley are mild (40-55°F) most winter days. Bryce Canyon is stunning in snow and rents snowshoes. Northern Utah (Salt Lake, Park City) is full ski season. Roads to some canyon areas and the north rim of the Grand Canyon close November-May.',
        tag: 'Hidden Gem',
      },
    ],
  },
  {
    topic: 'Desert Safety',
    icon: '&#9888;',
    tagline: 'Utah\'s desert is stunning but unforgiving — heat, UV, snakes, and dehydration are real risks',
    gradient: 'linear-gradient(135deg, #E94560 0%, #B83550 100%)',
    tips: [
      {
        title: 'Hydration — The Desert Rule',
        html: 'Dehydration in Utah\'s canyon country is the #1 cause of hiker emergencies. The desert air and high elevation (Moab is 4,000ft, most trails are 5,000-7,000ft) pull moisture from your body faster than you realize. Drink 1 liter per hour of active hiking in summer. A <a href="https://www.amazon.com/dp/B01LA5FCJ2?tag=discoverphili-20" target="_blank" rel="noopener">CamelBak Crux 3L hydration reservoir</a> is the best insurance for long desert days. There are no water sources in most canyon country — carry everything you need. Filter capability (<a href="https://www.amazon.com/dp/B09R8KRRDX?tag=discoverphili-20" target="_blank" rel="noopener">Hydro Flask 32oz</a> keeps water cold even at 100°F) matters on multi-day trips.',
        description: 'Dehydration in Utah\'s canyon country is the #1 cause of hiker emergencies. Drink 1 liter per hour of active hiking in summer. There are no water sources in most canyon country — carry everything you need.',
        tag: 'Critical',
      },
      {
        title: 'Extreme UV at Altitude',
        html: 'Utah\'s canyon country sits at 4,000-8,000ft — UV intensity is 25-40% stronger than sea level, and red rock reflects it back at you from all directions. Apply SPF 50+ sunscreen every 2 hours, wear a <a href="https://www.amazon.com/dp/B07NPPJH21?tag=discoverphili-20" target="_blank" rel="noopener">Columbia Bora Bora Booney hat</a>, and wear a <a href="https://www.amazon.com/dp/B08FGX3G41?tag=discoverphili-20" target="_blank" rel="noopener">Columbia PFG long-sleeve sun shirt</a> — it\'s cooler than it sounds and prevents serious burns. <a href="https://www.amazon.com/dp/B0BHL23CDX?tag=discoverphili-20" target="_blank" rel="noopener">Polarized sunglasses</a> are not optional — sandstone glare causes real eye strain on long days.',
        description: 'UV intensity is 25-40% stronger at Utah\'s elevation. Apply SPF 50+ every 2 hours, wear a wide-brim hat, sun shirt, and polarized sunglasses. Sandstone reflects UV from all directions.',
        tag: 'Important',
      },
      {
        title: 'Snakes in Red Rock Country',
        html: 'Great Basin Rattlesnakes are common in southern Utah\'s red rock terrain — Zion, Canyonlands, Capitol Reef, and Grand Staircase-Escalante all have active populations. They are not aggressive but will strike if surprised or cornered. Watch where you step, especially around boulders and ledges, and never reach into cracks or under rocks you cannot see into. For serious slot canyon and off-trail hiking, <a href="https://www.amazon.com/dp/B00ITZDL90?tag=discoverphili-20" target="_blank" rel="noopener">TurtleSkin SnakeArmor Gaiters</a> provide genuine bite protection on the lower leg — the most common strike zone.',
        description: 'Great Basin Rattlesnakes are common in southern Utah\'s red rock terrain. Watch where you step around boulders and ledges. Never reach into cracks or under rocks you cannot see. Snake gaiters provide bite protection for serious off-trail hiking.',
        tag: 'Be Prepared',
      },
      {
        title: 'Flash Flood & Slot Canyon Risk',
        description: 'Flash floods are the deadliest hazard in Utah slot canyons — walls funnel water from storms that can be 20 miles away and invisible from the canyon floor. Before entering any slot canyon (The Narrows, Buckskin Gulch, Peek-a-Boo, Antelope Canyon), check the NWS forecast for the entire watershed, not just where you are standing. Never enter a slot canyon if there is any chance of rain upstream. Antelope Canyon flood deaths have occurred — always go with a licensed guide.',
        tag: 'Critical',
      },
    ],
  },
  {
    topic: 'What to Pack',
    icon: '&#127890;',
    tagline: 'Desert hiking demands different gear than most other environments — prepare for heat, cold nights, and technical terrain',
    gradient: 'linear-gradient(135deg, #0D7377 0%, #14B8A6 100%)',
    tips: [
      {
        title: 'Hiking Essentials',
        html: '<a href="https://www.amazon.com/dp/B0C64B38Z8?tag=discoverphili-20" target="_blank" rel="noopener">Merrell Moab 3 Waterproof Boots</a> handle Utah\'s slickrock, sandy wash crossings, and technical terrain. Wear <a href="https://www.amazon.com/dp/B000XIEAH8?tag=discoverphili-20" target="_blank" rel="noopener">Darn Tough Hiker Socks</a> — blisters on a 3-day canyon trip are trip-ending. Carry an <a href="https://www.amazon.com/dp/B01I2P52WU?tag=discoverphili-20" target="_blank" rel="noopener">Osprey Daylite Plus 20L daypack</a> and trekking poles — <a href="https://www.amazon.com/dp/B077SQ17JV?tag=discoverphili-20" target="_blank" rel="noopener">Black Diamond Distance Carbon Z poles</a> are worth every dollar on steep descents in Bryce and Zion. For multi-day trips, <a href="https://www.amazon.com/dp/B082LPPKS8?tag=discoverphili-20" target="_blank" rel="noopener">Dr. Scholl\'s Moleskin Plus</a> treats blisters before they wreck a trip. Families with young children should look at the <a href="https://www.amazon.com/dp/B0DZ9J8THX?tag=discoverphili-20" target="_blank" rel="noopener">Osprey Poco Child Carrier</a>.',
        description: 'Waterproof boots, quality socks, a 20L daypack, trekking poles, moleskin for blisters, and a headlamp are must-haves for Utah canyon hiking.',
        tag: 'Essential',
      },
      {
        title: 'Navigation & Night Hiking',
        html: 'A <a href="https://www.amazon.com/dp/B09NQK2581?tag=discoverphili-20" target="_blank" rel="noopener">Black Diamond Spot 400 Headlamp</a> is essential — many Utah desert hikes start before dawn to beat the heat. For Goblin Valley and Bryce Canyon stargazing nights, a <a href="https://www.amazon.com/dp/B09TND94HB?tag=discoverphili-20" target="_blank" rel="noopener">Black Diamond Cosmo Headlamp</a> with a red-light mode preserves night vision. Astrophotographers should bring a <a href="https://www.amazon.com/dp/B01K7M0JEM?tag=discoverphili-20" target="_blank" rel="noopener">phone mount for stargazing apps</a>. Download offline maps before leaving cell range — many canyon areas have no coverage.',
        description: 'A headlamp with red-light mode is essential for pre-dawn starts and stargazing. Download offline maps before entering canyon country — cell coverage disappears fast.',
        tag: 'Important',
      },
      {
        title: 'Photography & Drone Gear',
        html: 'Utah is one of the most photographed landscapes in the world for good reason. A <a href="https://www.amazon.com/dp/B0CFF1SJ3P?tag=discoverphili-20" target="_blank" rel="noopener">DJI Mini 4 Pro drone</a> is legal in state parks and most BLM land (not in national parks — check regulations). A <a href="https://www.amazon.com/dp/B085BQS6K4?tag=discoverphili-20" target="_blank" rel="noopener">Peak Design Travel Tripod</a> handles canyon and slot photography where golden hour light lasts only minutes. A <a href="https://www.amazon.com/dp/B08V1DPQ69?tag=discoverphili-20" target="_blank" rel="noopener">K&F Concept ND Filter Set</a> tames harsh desert light for video and long-exposure shots. Keep a <a href="https://www.amazon.com/dp/B005D2JE2A?tag=discoverphili-20" target="_blank" rel="noopener">Pelican memory card case</a> to protect cards from the omnipresent red sand.',
        description: 'Utah rewards serious photographers. A drone (legal in state parks, not national parks), travel tripod, ND filters, and a protected memory card case are the core kit.',
      },
      {
        title: 'Canyoneering Gear',
        html: 'Technical slot canyons require proper rappelling gear — always go with a guide if you are new. For experienced canyoneers: a <a href="https://www.amazon.com/dp/B0BSBDZK44?tag=discoverphili-20" target="_blank" rel="noopener">Petzl BOREO Helmet</a> protects your head in tight passages, and <a href="https://www.amazon.com/dp/B00ACM4DRC?tag=discoverphili-20" target="_blank" rel="noopener">Petzl CORDEX Belay Gloves</a> protect your hands on rope descents. Wetsuits are required for The Subway and many water slots — rental is available in Springdale near Zion. Waterproof your pack contents — slot canyon pools can be chest-deep.',
        description: 'Technical slot canyons require helmets, belay gloves, and wetsuits. Always hire a guide if you are not experienced — Zion canyon deaths occur every year.',
        tag: 'Be Prepared',
      },
      {
        title: 'MTB & Cycling Gear',
        html: 'Moab is world-famous for mountain biking — Slickrock Trail, Porcupine Rim, and the Whole Enchilada are bucket-list rides. Always carry a <a href="https://www.amazon.com/dp/B09PZ98JXB?tag=discoverphili-20" target="_blank" rel="noopener">CamelBak M.U.L.E. 12 hydration pack</a> on desert rides — dehydration on technical trails is dangerous. <a href="https://www.amazon.com/dp/B0B8N8Z2RV?tag=discoverphili-20" target="_blank" rel="noopener">Fox Racing Ranger MTB Gloves</a> provide grip on rough Moab rock. <a href="https://www.amazon.com/dp/B0BZ958FTJ?tag=discoverphili-20" target="_blank" rel="noopener">G-Form Pro-X3 Knee Pads</a> are essential for technical descents — Moab trails will wreck unprotected knees.',
        description: 'Moab is a world-class MTB destination. A hydration pack, MTB gloves, and knee pads are essential for technical desert trails.',
      },
      {
        title: 'Road Trip & Camp Essentials',
        html: 'Utah road trips cover serious distances with few services — an <a href="https://www.amazon.com/dp/B0C1HP8N5D?tag=discoverphili-20" target="_blank" rel="noopener">iOttie car mount</a> and <a href="https://www.amazon.com/dp/B0843SCLYH?tag=discoverphili-20" target="_blank" rel="noopener">Anker car charger</a> keep navigation running. An <a href="https://www.amazon.com/dp/B01KIFISX2?tag=discoverphili-20" target="_blank" rel="noopener">EcoNour car sun shade</a> is essential when parked in desert sun. The <a href="https://www.amazon.com/dp/B01M07GTOE?tag=discoverphili-20" target="_blank" rel="noopener">Helinox Chair Zero</a> packs tiny and turns any canyon overlook into a proper sunset seat. An <a href="https://www.amazon.com/dp/B001DDTE5A?tag=discoverphili-20" target="_blank" rel="noopener">ENO DoubleNest Hammock</a> hangs between cottonwoods along canyon rivers. Keep a <a href="https://www.amazon.com/dp/B0CQBX3JZ6?tag=discoverphili-20" target="_blank" rel="noopener">roadside emergency kit</a> in the trunk — cell service is nonexistent in much of canyon country. A <a href="https://www.amazon.com/dp/B0DWCPS2Y4?tag=discoverphili-20" target="_blank" rel="noopener">high-capacity Anker power bank</a> keeps devices alive between outlet access. A <a href="https://www.amazon.com/dp/B01N7ILPEL?tag=discoverphili-20" target="_blank" rel="noopener">TSA lock</a> secures your bag at trailhead parking areas where car break-ins are common.',
        description: 'Car mount, charger, sun shade, camp chair, hammock, emergency kit, and power bank are the road trip toolkit for Utah\'s remote canyon country.',
      },
      {
        title: 'Skiing & Winter Gear',
        html: 'Utah gets an average of 500 inches of snow per year at Alta and Snowbird — "the Greatest Snow on Earth" is not marketing. For ski trips: a <a href="https://www.amazon.com/dp/B00DG2TNB6?tag=discoverphili-20" target="_blank" rel="noopener">retractable cable ski lock</a> secures equipment when you stop for lunch. Bring <a href="https://www.amazon.com/dp/B0B3JSRZFJ?tag=discoverphili-20" target="_blank" rel="noopener">binoculars</a> for spotting wildlife from the resort — moose and foxes are common near Alta. Gaiter-style pants stay clean in Utah\'s dry powder, and layers are critical — Snowbird summits hit -20°F in storms.',
        description: 'Alta and Snowbird receive 500+ inches annually. A ski lock, quality goggles, and extra layers for summit temperatures are essential. Utah\'s dry powder is unlike anywhere else.',
        tag: 'Pro Tip',
      },
    ],
  },
  {
    topic: 'Money & Budget',
    icon: '&#128176;',
    tagline: 'Utah is far more affordable than coastal destinations — but national park fees and gear add up',
    gradient: 'linear-gradient(135deg, #E94560 0%, #B83550 100%)',
    tips: [
      {
        title: 'National Park Fees',
        description: 'Each of the Mighty Five charges $35/vehicle for a 7-day pass. The America the Beautiful Annual Pass ($80) covers all five parks plus every national monument, recreation area, and national forest in the US. It pays for itself after visiting just three parks and is the single best travel investment for a Utah trip. Available at any park entrance or at recreation.gov.',
        tag: 'Essential',
      },
      {
        title: 'Daily Budget Ranges',
        description: 'Budget: $80-120/day — campground ($20-35/night), grocery store meals cooked at camp, free hiking. Mid-range: $150-250/day — motel or mid-tier lodging ($80-150/night), restaurant lunches, tours. Luxury: $350+/day — Amangiri ($2,000+/night), private guides, helicopter tours. A 7-day Utah road trip for two (mid-range) runs $2,500-3,500 all-in including flights, car rental, accommodation, food, and activities.',
      },
      {
        title: 'Saving Money in Utah',
        description: 'Camp instead of staying in Moab — campsite reservations at recreation.gov ($20-35/night) versus $150-300/night motels. Visit Goblin Valley, Kodachrome Basin, and Dead Horse Point State Park ($15-20/vehicle) instead of always paying national park fees. Cook meals — Moab has a City Market grocery store, and SLC has everything. Visit Bryce Canyon in winter for $0 crowds and stunning snow-dusted hoodoos.',
        tag: 'Pro Tip',
      },
      {
        title: 'Payment & Cell Coverage',
        description: 'Credit cards are accepted in towns but carry cash for campsite host fees, roadside vendors, and Navajo Nation services near Monument Valley and Antelope Canyon. Cell coverage disappears completely between Escalante and Hanksville, and throughout Grand Staircase-Escalante. Download offline maps (Maps.me, Gaia GPS) and the Zion, Arches, and Bryce Canyon NPS apps before leaving cell range. Verizon has the best rural coverage in southern Utah.',
      },
    ],
  },
];

const faqItems = [
  { question: 'Do I need a car in Utah?', answer: 'Yes — there is no meaningful public transit connecting Utah\'s national parks. A rental car is essential. From Zion\'s shuttle system (required in the main canyon) to Canyonlands\' remote districts, you will need your own vehicle everywhere outside of central Salt Lake City. Book an AWD vehicle for spring or after any rain — many dirt roads become impassable for 2WD vehicles.' },
  { question: 'When is the best time to visit Zion and Arches?', answer: 'Spring (March-May) and fall (September-November) are ideal for both — moderate temperatures, wildflowers or fall color, and manageable crowds. Summer is extremely hot in canyon country (Moab hits 100-108°F in July) but doable with early morning starts. Zion in winter is underrated — uncrowded, mild valley temperatures, and dramatic light. Arches requires timed entry permits April through October.' },
  { question: 'How far in advance should I book Utah national park permits?', answer: 'The Wave lottery requires applying 4 months ahead at recreation.gov (limited day-before lottery also available). Zion shuttle reservations open 3 days before in summer. Arches timed entry opens 1-5 days before. The Subway in Zion requires a permit by lottery — apply 3+ months ahead. Antelope Canyon (Page, AZ) tours sell out 3-6 months ahead in spring. Book accommodation in Moab and Springdale 4-6 months ahead for summer and fall.' },
  { question: 'Is Utah safe for beginner hikers?', answer: 'Yes, with caveats. Many Mighty Five trails are well-marked and manageable for beginners (Angel\'s Landing lower section, Bryce Canyon rim trail, Delicate Arch). But Utah\'s desert adds risks that East Coast or European hikers don\'t expect: extreme heat, limited water, UV radiation at altitude, and flash flood hazard in slot canyons. Carry more water than you think you need, start hikes before 8am in summer, and never enter a slot canyon if there is rain in the forecast.' },
  { question: 'Are there rattlesnakes in Utah national parks?', answer: 'Yes. Great Basin Rattlesnakes are present in all of Utah\'s southern national parks and in Grand Staircase-Escalante. They are most active spring through fall. Bites are rare but serious — watch where you step, especially around boulders and ledges, and never reach into crevices without looking first. Do not approach or handle them. In the extremely unlikely event of a bite, keep the victim calm and still, and get to a hospital immediately.' },
  { question: 'Can I fly a drone in Utah national parks?', answer: 'No — drone use is prohibited in all national parks (Zion, Arches, Canyonlands, Bryce Canyon, Capitol Reef). Drones are permitted on most BLM land (which surrounds the parks) and in most state parks including Goblin Valley and Dead Horse Point. Always check specific regulations before flying. The DJI Mini 4 Pro requires FAA Part 107 certification for commercial use and registration for recreational use.' },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  faqItems={faqItems}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="menu-hero">
    <div class="menu-hero-bg"></div>
    <div class="menu-hero-gradient"></div>
    <div class="menu-hero-noise"></div>
    <div class="menu-hero-content">
      <h1 class="menu-hero-title">Utah Practical Guide</h1>
      <p class="menu-hero-subtitle">Permits, desert safety, canyon hiking, and everything you need to know before setting foot in one of the most spectacular landscapes on Earth.</p>
      <div class="menu-hero-meta">
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Topics</span>
          <span class="menu-hero-meta-value">6</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Tips</span>
          <span class="menu-hero-meta-value">27</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">FAQ</span>
          <span class="menu-hero-meta-value">6</span>
        </div>
      </div>
    </div>
    <div class="menu-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="menu-personal reveal">
    <div class="container-content">
      <blockquote class="menu-personal-quote">
        <p>The number one mistake first-time Utah visitors make is underestimating the permit situation. You cannot just show up to The Wave, The Subway, or Antelope Canyon. Plan 4-6 months ahead for the iconic slots, buy your America the Beautiful pass before you arrive, and respect the desert heat — it will shut you down fast if you ignore it. The rewards are some of the most otherworldly landscapes on the planet.</p>
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- Intro -->
  <section class="menu-intro reveal">
    <div class="container-content">
      <div class="menu-intro-card">
        <p class="menu-intro-text">We've organized essential Utah travel advice into six categories — <strong>Getting to Utah</strong>, <strong>Permits & Planning</strong>, <strong>When to Visit</strong>, <strong>Desert Safety</strong>, <strong>What to Pack</strong>, and <strong>Money & Budget</strong>. Practical, honest, no-fluff guidance for canyon country.</p>
      </div>
    </div>
  </section>

  <!-- Tip Sections -->
  {sections.map((section) => (
    <section class="menu-region reveal">
      <div class="container-content">
        <div class="menu-region-header" style={`background: ${section.gradient};`}>
          <div class="menu-region-header-inner">
            <h2 class="menu-region-name">{section.topic}</h2>
            <p class="menu-region-tagline">{section.tagline}</p>
            <span class="menu-region-count">{section.tips.length} tips</span>
          </div>
