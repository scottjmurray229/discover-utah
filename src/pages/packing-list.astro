---
import BaseLayout from '../layouts/BaseLayout.astro';
import PackingList from '../components/PackingList.astro';
import FAQ from '../components/FAQ.astro';
import EmailCapture from '../components/EmailCapture.astro';
import FTCDisclosure from '../components/FTCDisclosure.astro';
import { UTAH_PACKING_FAQS, SITE_CONFIG } from '../data/packing-list';
import { PACKING_BASE } from '../data/packing-base';

const title = 'Utah Packing List 2026 — What to Pack for Zion, Bryce, Arches & Moab';
const description = 'The complete Utah packing list: hydration pack, waterproof hiking boots, layering system for desert temperature swings, and high-altitude sun protection. Interactive checklist.';
const canonicalUrl = 'https://discoverutah.info/packing-list/';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Pack for Utah National Parks',
  description: 'A complete packing guide for Utah covering Zion, Bryce Canyon, Arches, and Canyonlands.',
  step: [
    { '@type': 'HowToStep', name: 'Hydration System', text: 'Carry 3–4 liters of water minimum — dehydration is the top cause of park rescues in Utah.' },
    { '@type': 'HowToStep', name: 'Waterproof Boots', text: 'Zion Narrows wading requires waterproof footwear — trail runners get destroyed in the Virgin River.' },
    { '@type': 'HowToStep', name: 'Layering System', text: 'Utah has 50-degree daily temperature swings — base, mid, and shell layers cover all conditions.' },
    { '@type': 'HowToStep', name: 'High-Altitude Sun Protection', text: 'Bryce Canyon at 8,000 ft has 25% more UV than sea level — SPF 50 and a wide-brim hat are essential.' },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Utah National Parks Packing Essentials',
  itemListElement: PACKING_BASE.slice(0, 8).map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
  })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: UTAH_PACKING_FAQS.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Discover Utah', item: 'https://discoverutah.info/' },
    { '@type': 'ListItem', position: 2, name: 'Packing List', item: canonicalUrl },
  ],
};

const categoryLabels: Record<string, string> = {
  'documents': 'Documents & Entry',
  'clothing': 'Clothing & Layers',
  'toiletries': 'Toiletries & Health',
  'electronics': 'Electronics & Power',
  'destination': 'Utah Essentials',
  'money': 'Money & Cards',
  'daypack': 'Day Pack Items',
  'optional': 'Optional / Nice to Have',
};
---

<BaseLayout {title} {description} {canonicalUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="pl-hero">
    <div class="pl-hero-inner container-content">
      <nav class="pl-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Discover Utah</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Packing List</span>
      </nav>
      <h1 class="pl-hero-title">Utah Packing List 2026</h1>
      <p class="pl-hero-subtitle">Interactive checklist for Zion, Bryce Canyon, Arches, Canyonlands, and Moab — with gear picks for desert hiking and slot canyon adventures.</p>
      <div class="pl-chips">
        <span class="pl-chip">🏔️ Desert / Alpine (extreme temperature swings)</span>
        <span class="pl-chip">⚡ 120V / Type A/B</span>
        <span class="pl-chip">💵 USD</span>
        <span class="pl-chip">💧 Hydration: carry 3–4 liters minimum</span>
      </div>
    </div>
  </section>

  <FTCDisclosure placement="inline" />

  <!-- Laundry Strategy -->
  <section class="laundry-section container-content">
    <h2 class="laundry-title">Laundry Strategy for Utah</h2>
    <p class="laundry-body">Pack for 5–6 days and plan to wash once mid-trip. Springdale (Zion gateway) has laundromats at $2–4/load. Moab has several coin laundries near downtown. Quick-dry synthetics are worth the investment — you will sweat heavily on canyon hikes and need clean layers for cold evenings. Avoid packing cotton for multi-day park trips.</p>
  </section>

  <!-- Interactive Packing List -->
  <PackingList config={SITE_CONFIG} baseItems={PACKING_BASE} {categoryLabels} />

  <!-- Gear Recommendations -->
  <section class="gear-section container-content">
    <h2 class="gear-title">Gear We Recommend for Utah</h2>
    <p class="gear-subtitle">Trail-tested picks for the Mighty Five national parks and beyond.</p>
    <div class="gear-grid">
      {SITE_CONFIG.gearRecommendations.map(gear => (
        <div class="gear-card">
          <div class="gear-card-header">
            <h3 class="gear-card-name">{gear.name}</h3>
            {gear.affiliatePrice && <span class="gear-card-price">{gear.affiliatePrice}</span>}
          </div>
          <p class="gear-card-reason">{gear.reason}</p>
          <a
            href={`https://www.amazon.com/s?k=${gear.amazonSearchFallback}&tag=${SITE_CONFIG.affiliateTag}`}
            target="_blank"
            rel="noopener sponsored"
            class="gear-card-link"
          >
            View on Amazon →
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section container-content">
    <h2 class="faq-title">Utah Packing FAQ</h2>
    <FAQ items={UTAH_PACKING_FAQS} />
  </section>

  <!-- Email Capture -->
  <EmailCapture
    leadMagnet="Get My Free Utah National Parks Packing Checklist"
    description="The complete printable packing list for Utah's Mighty Five — with gear links, permit tips, and Zion Narrows wading gear guide."
    bullets={[
      'Printable checklist for Zion, Bryce, Arches, and Canyonlands',
      'Zion Narrows wading gear guide (what to rent vs. bring)',
      'Angels Landing and The Wave permit strategy',
      'Seasonal packing guide for spring snow to summer desert heat',
    ]}
    guideTag="packing-utah"
  />

  <!-- Related Links -->
  <section class="related-section container-content">
    <h2 class="related-title">Plan Your Utah Trip</h2>
    <div class="related-grid">
      <a href="/plan/" class="related-card">
        <span class="related-icon">🗺️</span>
        <span class="related-label">AI Trip Planner</span>
        <span class="related-desc">Build a custom Utah itinerary</span>
      </a>
      <a href="/outdoors/" class="related-card">
        <span class="related-icon">🏔️</span>
        <span class="related-label">Outdoor Adventures</span>
        <span class="related-desc">Hiking, canyoneering, and stargazing</span>
      </a>
      <a href="/practical/" class="related-card">
        <span class="related-icon">🗺️</span>
        <span class="related-label">Practical Guide</span>
        <span class="related-desc">Permits, transport, and park tips</span>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .pl-hero { background: linear-gradient(135deg, #7C2D12 0%, #C2410C 50%, #EA580C 100%); color: white; padding: 80px 0 48px; margin-top: -1px; }
  .pl-hero-inner { max-width: var(--content-width-lg); }
  .pl-breadcrumb { font-size: 0.85rem; opacity: 0.8; margin-bottom: 16px; display: flex; gap: 8px; align-items: center; }
  .pl-breadcrumb a { color: white; text-decoration: none; }
  .pl-breadcrumb a:hover { text-decoration: underline; }
  .pl-hero-title { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: var(--weight-extrabold); margin: 0 0 12px; line-height: 1.15; }
  .pl-hero-subtitle { font-size: 1.1rem; opacity: 0.92; max-width: 600px; margin: 0 0 24px; line-height: 1.6; }
  .pl-chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .pl-chip { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 20px; padding: 6px 14px; font-size: 0.85rem; font-weight: var(--weight-medium); }
  .laundry-section { padding: 40px 0 0; max-width: var(--content-width-prose); }
  .laundry-title { font-size: 1.35rem; font-weight: var(--weight-bold); color: var(--color-deep-night); margin: 0 0 12px; }
  .laundry-body { color: var(--color-slate); line-height: 1.7; margin: 0; }
  .gear-section { padding: 48px 0; }
  .gear-title { font-size: 1.75rem; font-weight: var(--weight-bold); color: var(--color-deep-night); margin: 0 0 8px; }
  .gear-subtitle { color: var(--color-slate); margin: 0 0 32px; }
  .gear-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
  .gear-card { background: white; border: 1px solid var(--color-sand-dark, #EBE4D8); border-radius: 12px; padding: 20px; display: flex; flex-direction: column; gap: 10px; }
  .gear-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
  .gear-card-name { font-size: 1rem; font-weight: var(--weight-semibold); color: var(--color-deep-night); margin: 0; }
  .gear-card-price { font-size: 0.85rem; font-weight: var(--weight-semibold); color: var(--color-ocean-teal); white-space: nowrap; }
  .gear-card-reason { font-size: 0.9rem; color: var(--color-slate); line-height: 1.6; margin: 0; flex: 1; }
  .gear-card-link { font-size: 0.85rem; font-weight: var(--weight-semibold); color: var(--color-ocean-teal); text-decoration: none; }
  .gear-card-link:hover { text-decoration: underline; }
  .faq-section { padding: 48px 0; max-width: var(--content-width-prose); }
  .faq-title { font-size: 1.75rem; font-weight: var(--weight-bold); color: var(--color-deep-night); margin: 0 0 24px; }
  .related-section { padding: 48px 0 64px; }
  .related-title { font-size: 1.5rem; font-weight: var(--weight-bold); color: var(--color-deep-night); margin: 0 0 24px; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; }
  .related-card { display: flex; flex-direction: column; gap: 6px; padding: 20px; background: white; border: 1px solid var(--color-sand-dark, #EBE4D8); border-radius: 12px; text-decoration: none; transition: box-shadow 0.2s, transform 0.2s; }
  .related-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .related-icon { font-size: 1.5rem; }
  .related-label { font-size: 0.95rem; font-weight: var(--weight-semibold); color: var(--color-deep-night); }
  .related-desc { font-size: 0.82rem; color: var(--color-slate); }
</style>
