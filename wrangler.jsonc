{
	"main": "dist/_worker.js/index.js",
	"name": "discover-utah",
  "compatibility_date": "2026-02-04",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "trip-planner-cache-utah",
      "database_id": "5a51152c-bb32-486c-b5c9-8064f61e8481"
    }
  ]
}
